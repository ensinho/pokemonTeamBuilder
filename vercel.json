{
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/refresh-tournaments",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/render-meta.js": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/api/render-meta"
    }
  ]
}
