rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['enzopo625@gmail.com'];
    }

    match /artifacts/{appId} {

      match /users/{userId}/{document=**} {
        allow read, write: if isOwner(userId);
      }

      match /users/{userId}/profile/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      match /public/data/teams/{teamId} {
        allow read: if true;
        allow create: if isSignedIn() && validSharedTeam();
        allow update, delete: if isAdmin();

        function validSharedTeam() {
          return request.resource.data.name is string
            && request.resource.data.name.size() <= 100
            && request.resource.data.pokemons is list
            && request.resource.data.pokemons.size() <= 6;
        }
      }

      match /public/data/forumTopics/{topicId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if isAdmin()
          || (isSignedIn() && resource.data.createdBy == request.auth.uid)
          || (isSignedIn() && onlyTouchesActivityFields());
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.createdBy == request.auth.uid);

        // Any signed-in user may bump the topic's activity metadata when they
        // post a reply, without being able to alter its title/category/owner.
        function onlyTouchesActivityFields() {
          return request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastActivityAt', 'messageCount', 'lastMessageText']);
        }

        match /messages/{messageId} {
          allow read: if true;
          allow create: if isSignedIn()
            && request.resource.data.createdBy == request.auth.uid;
          allow update, delete: if isAdmin()
            || (isSignedIn() && resource.data.createdBy == request.auth.uid);
        }
      }

      match /feedback/likes {
        allow read: if true;
        allow create, update: if isSignedIn() && touchesOnlyOwnLike();
        allow delete: if isAdmin();

        function touchesOnlyOwnLike() {
          let willHave = request.resource.data.get('userIds', []);
          let alreadyHas = resource == null ? [] : resource.data.get('userIds', []);
          let added = willHave.removeAll(alreadyHas);
          let removed = alreadyHas.removeAll(willHave);
          return added.hasOnly([request.auth.uid])
            && removed.hasOnly([request.auth.uid]);
        }
      }

      match /feedback/{docId} {
        allow create: if isSignedIn();
        allow read, update, delete: if isAdmin();
      }

      match /suggestions/{docId} {
        allow create: if isSignedIn();
        allow read, update, delete: if isAdmin();
      }

      match /pokemons/{docId} {
        allow read: if true;
        allow write: if false;
      }
    }
  }
}
